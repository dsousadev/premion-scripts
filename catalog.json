{
  "version": 1,
  "scripts": [
    {
      "id": "ctf-tool",
      "name": "CTF Tool",
      "version": "1.0.0",
      "description": "Convert Creative Trafficking Form xlsx files into Prism Bulk-Associate-Line-Items uploads",
      "file": "scripts/ctf-tool.user.js",
      "matches": ["https://prism.octillion.tv/*"],
      "runAt": "document_idle",
      "enabled": true,
      "downloadUrl": "https://raw.githubusercontent.com/dsousadev/premion-scripts/main/scripts/ctf-tool.user.js",
      "requires": [
        {
          "url": "https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js",
          "integrity": "sha256-zAFRMKqFIefwiPiImOupSczcv7ON8L0Sm0S3Jzw6b0E="
        },
        {
          "url": "https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js",
          "integrity": "sha256-fknaaFiOJQ27i7oZDSyqirN4fMAoS9odiy+AXE33Qsk="
        }
      ]
    },
    {
      "id": "email-helper",
      "name": "Email Helper",
      "version": "1.0.0",
      "description": "Generate Outlook-compatible .eml drafts from Google Sheets station data",
      "file": "scripts/email-helper.user.js",
      "matches": ["https://docs.google.com/spreadsheets/d/1EQwTclB0QPJwgIEmdX7RM9kEgxbaMuuSfDEndCartlI/*"],
      "runAt": "document_idle",
      "enabled": true,
      "downloadUrl": "https://raw.githubusercontent.com/dsousadev/premion-scripts/main/scripts/email-helper.user.js"
    }
  ]
}
